# ── Circle ───────────────────────────────────────────────────
# Get from https://console.circle.com (App Kit Key)
NEXT_PUBLIC_APP_KIT_KEY=

# ── Reown / WalletConnect ───────────────────────────────────
# Get a free Project ID at https://cloud.reown.com
# Without this, WalletConnect QR-code pairing is disabled
# and you may see "HTTP 403" warnings in the console.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=f4eb5f6dd495dba1825caf09c4c94fd2

# ── Supabase (optional, for Phase 2) ─────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side only (never commit real values; use .env.local + a secret manager)
# Database password is the strongest credential - rotate immediately if leaked.
# SUPABASE_DB_PASSWORD=
