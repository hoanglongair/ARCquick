# ── Circle ───────────────────────────────────────────────────
# Get from https://console.circle.com (App Kit Key)
NEXT_PUBLIC_APP_KIT_KEY=

# ── Reown / WalletConnect ───────────────────────────────────
# Get a free Project ID at https://cloud.reown.com
# Without this, WalletConnect QR-code pairing is disabled
# and you may see "HTTP 403" warnings in the console.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=dien-vao-day

# ── Arc Testnet RPC (recommended for production) ─────────────
# Get a free Alchemy API key at https://dashboard.alchemy.com
# - Create a new app, pick chain "Arc Testnet" (chainId 5042002)
# - Enable the Node API and copy the API key from the app detail page
# - Paste it after /v2/ in the URL below
# When set, this URL is used as the PRIMARY transport for Arc Testnet,
# ahead of the public fallback RPCs. Leave empty to use only public RPCs.
NEXT_PUBLIC_ARC_RPC_URL=https://arc-testnet.g.alchemy.com/v2/your-alchemy-key-here

# ── Supabase (optional, for Phase 2) ─────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side only (never commit real values; use .env.local + a secret manager)
# Database password is the strongest credential - rotate immediately if leaked.
# SUPABASE_DB_PASSWORD=
